# DeepSeek API 配置 — 复制本文件为 .env 后填入真实值
# cp .env.example .env

# 必填：你的 DeepSeek API Key
DEEPSEEK_API_KEY=

# 可选：覆盖默认值
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
# DEEPSEEK_MODEL=deepseek-v4-pro
# PORT=8787

# CORS 白名单（逗号分隔的允许来源）。不配置默认本地 Vite 端口。
# 部署到公网时改成你的前端域名，例如 https://your-game.com
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# 限流：每个 IP 在 RATE_WINDOW_MS 毫秒内最多 RATE_MAX 次 /api/chat
# RATE_WINDOW_MS=60000
# RATE_MAX=20
